APP_NAME=StarRide
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

# Real-time / socket microservice (returned to mobile apps in API responses)
MICRO_SERVICE_APP_URL=/
MICRO_SERVICE_APP_FULL_URL=https://your-socket-server.example.com:8443

LOG_CHANNEL=daily
QUEUE_CONNECTION=database

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=starride
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Optional: master password override for certain API login flows
MASTER_PASS=

# -----------------------------------------------------------------------------
# Optional — uncomment and set when needed
# -----------------------------------------------------------------------------

# CACHE_DRIVER=file
# SESSION_DRIVER=file
# SESSION_LIFETIME=120
# BROADCAST_DRIVER=log

# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# REDIS_FOR_CONFIG=false

# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@example.com
# MAIL_FROM_NAME="${APP_NAME}"

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=

# FILESYSTEM_DRIVER=local

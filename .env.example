APP_NAME=StarRide
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

# Real-time / socket microservice (returned to mobile apps in API responses)
MICRO_SERVICE_APP_URL=/
MICRO_SERVICE_APP_FULL_URL=https://your-socket-server.example.com:8443

LOG_CHANNEL=daily
QUEUE_CONNECTION=database

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=starride
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Optional: master password override for certain API login flows
MASTER_PASS=

